# Apple Music API 設定
# 複製此檔案為 .env 並填入實際值

# .p8 私鑰檔路徑（絕對路徑或相對於專案根目錄）
APPLE_KEY_FILE=AuthKey_XXXXXXXXXX.p8

# Apple Developer Key ID（10 碼，即 .p8 檔名中的英數字）
APPLE_KEY_ID=XXXXXXXXXX

# Apple Developer Team ID（10 碼，於 Membership 頁面取得）
APPLE_TEAM_ID=XXXXXXXXXX

# Apple Music User Token（執行 `kkbox2applemusic auth` 取得）
# 設定後 chart --push 將直接使用此 token，無需每次瀏覽器授權
APPLE_USER_TOKEN=
